digraph modernism_woolf {
    graph [
        rankdir=LR
        fontname="Helvetica"
        fontsize=12
        bgcolor="#FAFAFA"
        pad=0.5
        splines=ortho
        nodesep=0.32
        ranksep=1.1
        size="11.69,8.27"
        ratio=compress
    ]
    node [
        fontname="Helvetica"
        fontsize=9
        style="filled,rounded"
        shape=box
        margin="0.15,0.09"
        width=2.2
    ]
    edge [
        fontname="Helvetica"
        fontsize=8
        color="#555555"
        arrowsize=0.55
    ]

    // ══════════════════════════════════════════════════════════════════════
    // ROOT
    // ══════════════════════════════════════════════════════════════════════
    ROOT [label="MODERNISM\n& VIRGINIA WOOLF"
          shape=ellipse fontsize=13 fontcolor=white width=2.8
          fillcolor="#1B2631" color="#0A0F15"]

    // ══════════════════════════════════════════════════════════════════════
    // BRANCH 1 – MODERNISM
    // ══════════════════════════════════════════════════════════════════════
    MOD [label="MODERNISM\n(early 20th century)"
         fillcolor="#1A5276" fontcolor=white color="#154360" fontsize=11]

    ROOT -> MOD

    M1 [label="Context: WW1, Einstein, Freud,\nMarx, Nietzsche\n→ disillusionment & fragmentation"    fillcolor="#AED6F1" color="#1A5276"]
    M2 [label="Rejected: Victorian realism,\ntraditional morality,\nfixed narrative structures"       fillcolor="#AED6F1" color="#1A5276"]
    M3 [label="Techniques: stream of consciousness,\ndiscontinuous narrative,\njuxtaposition, myth"   fillcolor="#AED6F1" color="#1A5276"]
    M4 [label="Themes: alienation, fragmentation,\nloss of certainty, urban life"                    fillcolor="#AED6F1" color="#1A5276"]
    M5 [label="Key writers: Conrad, T.S. Eliot,\nEzra Pound, Yeats, Joyce\n(global, often exiled)"   fillcolor="#AED6F1" color="#1A5276"]

    MOD -> M1
    MOD -> M2
    MOD -> M3
    MOD -> M4
    MOD -> M5

    // ══════════════════════════════════════════════════════════════════════
    // BRANCH 2 – VIRGINIA WOOLF
    // ══════════════════════════════════════════════════════════════════════
    VW [label="VIRGINIA WOOLF"
        fillcolor="#6C3483" fontcolor=white color="#5B2C6F" fontsize=11]

    ROOT -> VW
    MOD  -> VW [style=dashed color="#888888"]

    V1 [label="London 1882 – educated at home\nMarried Leonard Woolf (1912)\nHogarth Press (1917) · died 1941" fillcolor="#D7BDE2" color="#76448A"]
    V2 [label="Bloomsbury Group:\nWoolf, Forster, Keynes,\nRoger Fry"                                fillcolor="#D7BDE2" color="#76448A"]
    V3 [label="Style: stream of consciousness\ninner life over plot\npoetic, musical prose"          fillcolor="#D7BDE2" color="#76448A"]
    V4 [label="A Room of One's Own (1929):\nwomen need financial independence\nand personal space to create art" fillcolor="#D7BDE2" color="#76448A"]

    VW -> V1
    VW -> V2
    VW -> V3
    VW -> V4

    // ══════════════════════════════════════════════════════════════════════
    // BRANCH 3 – TO THE LIGHTHOUSE
    // ══════════════════════════════════════════════════════════════════════
    TTL [label="TO THE LIGHTHOUSE\n(1927)"
         fillcolor="#117A65" fontcolor=white color="#0E6655" fontsize=11]

    ROOT -> TTL
    VW   -> TTL [style=dashed color="#888888"]

    T1 [label="Autobiographical: Ramsay family\n= Woolf's own family\n(set in the Hebrides)"         fillcolor="#A2D9CE" color="#148F77"]

    STRUCT [label="3-Part Structure"
            fillcolor="#148F77" fontcolor=white color="#0E6655"]

    S1 [label="1. The Window:\nbefore WW1 · Ramsay family\nLily Briscoe begins painting"             fillcolor="#A2D9CE" color="#148F77"]
    S2 [label="2. Time Passes:\n10 years · WW1 · house empty\nMrs Ramsay, Prue, Andrew die"          fillcolor="#A2D9CE" color="#148F77"]
    S3 [label="3. The Lighthouse:\nafter WW1 · trip to lighthouse\nLily completes her painting"      fillcolor="#A2D9CE" color="#148F77"]

    T2 [label="Themes: time, memory, loss\nart as the only source of\nunity and meaning"             fillcolor="#A2D9CE" color="#148F77"]

    TTL    -> T1
    TTL    -> STRUCT
    STRUCT -> S1
    STRUCT -> S2
    STRUCT -> S3
    TTL    -> T2
}
